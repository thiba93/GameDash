generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  STAFF
  ADMIN
}

enum GameMode {
  RANKED
  UNRANKED
  FUN
}

enum QueueState {
  OFFLINE
  ONLINE
  IN_QUEUE
  IN_MATCH
}

enum MatchOutcome {
  WIN
  LOSS
  DRAW
}

enum MatchFormat {
  ONE_VS_ONE
  THREE_VS_THREE
}

enum CurrencyType {
  SOFT
  HARD
}

enum TransactionStatus {
  ACCEPTED
  REJECTED
}

enum RewardType {
  SOFT_CURRENCY
  COSMETIC
  TITLE
}

enum MapStatus {
  DRAFT
  BETA
  STABLE
  HIDDEN
}

enum SanctionType {
  WARNING
  SUSPENSION
  BAN
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String
  role           Role               @default(PLAYER)
  state          QueueState         @default(OFFLINE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  profile        PlayerProfile?
  progression    AccountProgression?
  refreshTokens  RefreshToken[]
  mmrRatings     PlayerMmr[]
  queueEntries   MatchmakingQueue[]
  matchEntries   MatchParticipant[]
  levelRewards   PlayerLevelRewardGrant[]
  transactions   Transaction[]
  wallet         Wallet?
  inventoryItems InventoryItem[]
  maps           GameMap[]
  mapVotes       MapVote[]
  mapTests       MapTest[]
  mapFavorites   MapFavorite[]
  mapReports     MapReport[]
  sanctions      Sanction[]
  moderationSignalsReviewed ModerationSignal[] @relation("ModerationSignalReviewer")
  auditLogs      AuditLog[]
}

model PlayerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  pseudo      String
  avatarUrl   String?
  region      String?
  bio         String?
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}

model MatchmakingQueue {
  id        String     @id @default(uuid())
  userId    String
  mode      GameMode
  state     QueueState @default(IN_QUEUE)
  queuedAt  DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mode, state, queuedAt])
}

model Match {
  id                  String             @id @default(uuid())
  mode                GameMode
  format              MatchFormat        @default(ONE_VS_ONE)
  startedAt           DateTime           @default(now())
  finishedAt          DateTime?
  winnerUserId        String?
  winnerTeam          Int?
  resultSubmittedById String?
  resultNotes         String?
  createdAt           DateTime           @default(now())
  participants        MatchParticipant[]
}

model MatchParticipant {
  id         String       @id @default(uuid())
  matchId    String
  userId     String
  team       Int?
  outcome    MatchOutcome?
  mmrBefore  Int?
  mmrAfter   Int?
  xpAwarded  Int?
  createdAt  DateTime     @default(now())
  match      Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId, createdAt])
}

model PlayerMmr {
  id        String   @id @default(uuid())
  userId    String
  mode      GameMode
  mmr       Int      @default(1000)
  rankTier  String   @default("BRONZE")
  rankDiv   String   @default("III")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mode])
}

model RankConfig {
  id        String   @id @default(uuid())
  mode      GameMode
  minMmr    Int
  maxMmr    Int?
  rank      String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mode, rank])
  @@index([mode, minMmr])
}

model AccountProgression {
  id         String   @id @default(uuid())
  userId     String   @unique
  level      Int      @default(1)
  lifetimeXp Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LevelReward {
  id         String     @id @default(uuid())
  level      Int
  code       String     @unique
  label      String
  rewardType RewardType
  quantity   Int?
  active     Boolean    @default(true)
  sortOrder  Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([level, active])
}

model PlayerLevelRewardGrant {
  id         String     @id @default(uuid())
  userId     String
  level      Int
  rewardCode String
  label      String
  rewardType RewardType
  quantity   Int?
  grantedAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardCode])
  @@index([userId, grantedAt])
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  softBalance Int      @default(0)
  hardBalance Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StoreItem {
  id           String       @id @default(uuid())
  itemCode     String       @unique
  name         String
  description  String?
  currencyType CurrencyType
  price        Int
  active       Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  transactions Transaction[]

  @@index([active, sortOrder])
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  storeItemId   String?
  itemCode      String?
  currencyType  CurrencyType
  unitPrice     Int
  quantity      Int
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  status        TransactionStatus @default(ACCEPTED)
  reason        String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeItem     StoreItem?        @relation(fields: [storeItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model InventoryItem {
  id                  String   @id @default(uuid())
  userId              String
  itemCode            String
  name                String
  quantity            Int      @default(1)
  equipped            Boolean  @default(false)
  sourceTransactionId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemCode])
  @@index([userId, itemCode])
}

model GameMap {
  id               String               @id @default(uuid())
  creatorId        String
  title            String
  description      String
  tags             String[]
  screenshots      String[]
  status           MapStatus            @default(DRAFT)
  popularityScore  Float                @default(0)
  reviewStatus     String               @default("pending")
  reportCount      Int                  @default(0)
  lastModerationAt DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  creator          User                 @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  versions         MapVersion[]
  votes            MapVote[]
  tests            MapTest[]
  favorites        MapFavorite[]
  reports          MapReport[]
  moderationEvents MapModerationEvent[]

  @@index([status, popularityScore])
  @@index([creatorId, createdAt])
}

model MapVersion {
  id           String   @id @default(uuid())
  mapId        String
  versionLabel String
  releaseNotes String
  createdAt    DateTime @default(now())
  map          GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, versionLabel])
}

model MapVote {
  id        String   @id @default(uuid())
  mapId     String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  map       GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mapId, userId])
}

model MapTest {
  id        String   @id @default(uuid())
  mapId     String
  userId    String
  completed Boolean  @default(true)
  createdAt DateTime @default(now())
  map       GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MapFavorite {
  id        String   @id @default(uuid())
  mapId     String
  userId    String
  createdAt DateTime @default(now())
  map       GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mapId, userId])
}

model MapReport {
  id         String   @id @default(uuid())
  mapId      String
  reporterId String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())
  map        GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([mapId, status])
  @@index([status, createdAt])
}

model MapModerationEvent {
  id        String   @id @default(uuid())
  mapId     String
  actorId   String
  action    String
  reason    String?
  createdAt DateTime @default(now())
  map       GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
}

model Sanction {
  id        String       @id @default(uuid())
  userId    String
  actorId   String?
  type      SanctionType
  reason    String
  status    String       @default("active")
  metadata  Json?
  startedAt DateTime     @default(now())
  endsAt    DateTime?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model StudioSetting {
  key         String   @id
  value       Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModerationSignal {
  id           String   @id @default(uuid())
  targetType   String
  targetId     String
  reason       String
  status       String   @default("open")
  source       String
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime @default(now())
  reviewedBy   User?    @relation("ModerationSignalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

model ModerationHistory {
  id             String    @id @default(uuid())
  actorId        String
  targetType     String
  targetId       String
  action         String
  reason         String
  metadata       Json?
  expiresAt      DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([targetType, targetId, createdAt])
  @@index([actorId, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
}

model RuntimeEvent {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  requestId String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@index([source, createdAt])
  @@index([requestId])
}
