generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  STAFF
  ADMIN
}

enum GameMode {
  RANKED
  UNRANKED
  FUN
}

enum QueueState {
  OFFLINE
  ONLINE
  IN_QUEUE
  IN_MATCH
}

enum MatchOutcome {
  WIN
  LOSS
  DRAW
}

enum CurrencyType {
  SOFT
  HARD
}

enum MapStatus {
  DRAFT
  BETA
  STABLE
  HIDDEN
}

enum SanctionType {
  WARNING
  SUSPENSION
  BAN
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String
  role           Role               @default(PLAYER)
  state          QueueState         @default(OFFLINE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  profile        PlayerProfile?
  refreshTokens  RefreshToken[]
  mmrRatings     PlayerMmr[]
  queueEntries   MatchmakingQueue[]
  matchEntries   MatchParticipant[]
  transactions   Transaction[]
  wallet         Wallet?
  inventoryItems InventoryItem[]
  maps           GameMap[]
  mapVotes       MapVote[]
  mapTests       MapTest[]
  mapFavorites   MapFavorite[]
  sanctions      Sanction[]
  auditLogs      AuditLog[]
}

model PlayerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  pseudo      String
  avatarUrl   String?
  region      String?
  bio         String?
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchmakingQueue {
  id        String    @id @default(uuid())
  userId    String
  mode      GameMode
  state     QueueState @default(IN_QUEUE)
  queuedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mode, state, queuedAt])
}

model Match {
  id           String             @id @default(uuid())
  mode         GameMode
  startedAt    DateTime           @default(now())
  finishedAt   DateTime?
  createdAt    DateTime           @default(now())
  participants MatchParticipant[]
}

model MatchParticipant {
  id         String       @id @default(uuid())
  matchId    String
  userId     String
  outcome    MatchOutcome?
  mmrBefore  Int?
  mmrAfter   Int?
  createdAt  DateTime     @default(now())
  match      Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId, createdAt])
}

model PlayerMmr {
  id         String    @id @default(uuid())
  userId     String
  mode       GameMode
  mmr        Int       @default(1000)
  rankTier   String    @default("BRONZE")
  rankDiv    String    @default("III")
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mode])
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  softBalance Int      @default(0)
  hardBalance Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StoreItem {
  id           String       @id @default(uuid())
  name         String
  description  String?
  currencyType CurrencyType
  price        Int
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  transactions Transaction[]
}

model Transaction {
  id           String       @id @default(uuid())
  userId       String
  storeItemId  String?
  currencyType CurrencyType
  amount       Int
  status       String       @default("accepted")
  metadata     Json?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeItem    StoreItem?   @relation(fields: [storeItemId], references: [id], onDelete: SetNull)
}

model InventoryItem {
  id          String   @id @default(uuid())
  userId      String
  itemCode    String
  equipped    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, itemCode])
}

model GameMap {
  id               String               @id @default(uuid())
  creatorId        String
  title            String
  description      String
  tags             String[]
  status           MapStatus            @default(DRAFT)
  popularityScore  Float                @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  creator          User                 @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  versions         MapVersion[]
  votes            MapVote[]
  tests            MapTest[]
  favorites        MapFavorite[]
  moderationEvents MapModerationEvent[]
}

model MapVersion {
  id           String   @id @default(uuid())
  mapId         String
  versionLabel  String
  releaseNotes  String
  createdAt     DateTime @default(now())
  map           GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, versionLabel])
}

model MapVote {
  id         String   @id @default(uuid())
  mapId      String
  userId     String
  value      Int
  createdAt  DateTime @default(now())
  map        GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mapId, userId])
}

model MapTest {
  id         String   @id @default(uuid())
  mapId      String
  userId     String
  completed  Boolean  @default(true)
  createdAt  DateTime @default(now())
  map        GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MapFavorite {
  id         String   @id @default(uuid())
  mapId      String
  userId     String
  createdAt  DateTime @default(now())
  map        GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mapId, userId])
}

model MapModerationEvent {
  id          String   @id @default(uuid())
  mapId        String
  actorId      String
  action       String
  reason       String?
  createdAt    DateTime @default(now())
  map          GameMap  @relation(fields: [mapId], references: [id], onDelete: Cascade)
}

model Sanction {
  id         String       @id @default(uuid())
  userId     String
  type       SanctionType
  reason     String
  startedAt  DateTime     @default(now())
  endsAt     DateTime?
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
}
