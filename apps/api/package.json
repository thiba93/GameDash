{
  "name": "@gamedash/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "prisma generate --schema=../../prisma/schema.prisma && tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/auth/auth.service.spec.ts && tsx src/progression/progression.service.spec.ts && tsx src/matchmaking/matchmaking.service.spec.ts && tsx src/economy/economy.service.spec.ts && tsx src/maps/maps.service.spec.ts && tsx src/admin/admin.service.spec.ts && tsx src/observability/observability.service.spec.ts && tsx src/observability/observability.middleware.spec.ts && tsx src/quality/critical-flows.spec.ts"
  },
  "dependencies": {
    "@gamedash/contracts": "workspace:*",
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/platform-socket.io": "^10.4.8",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
