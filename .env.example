# Copy this file to .env for local development.
# Never commit .env — it is listed in .gitignore.
# Values below are safe development defaults. Replace secrets before any deployment.

# ── API runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ── JWT secrets ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32, these values are examples

JWT_ACCESS_SECRET=YvVbnxvE/Zulr07ACd2NuaKz9QxXskXrY5ZEiMaGDiw=
JWT_REFRESH_SECRET=wupoBJ7KOdc8G4z2a+Kyvyu0eBF9eUiQKtmtZAic/M8= 

# Token TTLs (informational — currently hardcoded in auth.service.ts)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=30d

# ── Database ───────────────────────────────────────────────────────────────────
# Adjust user/password/host to match your local PostgreSQL install.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gamedash?schema=public

# ── Redis (reserved — not yet wired in code) ──────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Frontend → API URL ────────────────────────────────────────────────────────
# Must be prefixed NEXT_PUBLIC_ to be exposed to the browser bundle.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# ── CORS origin (reserved — enableCors() called without options in main.ts) ───
# WEB_ORIGIN=http://localhost:3000
