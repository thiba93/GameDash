# Copy this file to .env for local development.
# Values below are development-only defaults. Never reuse them in production.

# API runtime
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Local JWT secrets
JWT_ACCESS_SECRET=gamedash-local-access-secret-change-before-production-2026
JWT_REFRESH_SECRET=gamedash-local-refresh-secret-change-before-production-2026
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Data services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gamedash?schema=public
REDIS_URL=redis://localhost:6379

# Local app URLs
WEB_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:3001/api/v1
